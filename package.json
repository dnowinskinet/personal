{
  "name": "dnowinski",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": "^22.12.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "grift:arch": "node scripts/check-grift-boundaries.mjs",
    "grift:test": "npm run grift:arch && ng test --watch=false --browsers=ChromeHeadless --include=src/app/pages/experimental/grift-os-game/**/*.spec.ts",
    "push": "ng build --base-href /",
    "deploy:pages": "npm run push && angular-cli-ghpages --dir=dist/dnowinski/browser --cname=dnowinski.com",
    "serve:ssr:dnowinski": "node dist/dnowinski/server/server.mjs",
    "lint": "ng lint",
    "verify": "npm run lint && npm run build",
    "audit:prod": "npm audit --omit=dev",
    "deps:outdated": "npm outdated --long",
    "clean": "ng cache clean",
    "icons:sync": "node scripts/sync-fontawesome-icons.mjs",
    "game:balance": "node scripts/grift-os-balance-report.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/localize": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/platform-server": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/ssr": "^21.2.19",
    "@fontsource-variable/inter": "^5.2.8",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "express": "^5.2.1",
    "marked": "^18.0.4",
    "medium-zoom": "^1.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^22.20.1",
    "angular-cli-ghpages": "^3.1.0",
    "angular-eslint": "^21.4.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "jasmine-core": "^6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.5.21",
    "sass": "^1.101.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0"
  },
  "browser": {
    "fs": false,
    "path": false,
    "os": false,
    "url": false
  },
  "overrides": {
    "sockjs": {
      "uuid": "11.1.1"
    }
  }
}
